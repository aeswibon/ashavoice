# Example environment variables for AshaVoice project
# Copy this file to .env and fill in actual values if needed

# --- Core Application Settings ---
APP_NAME="AshaVoice Backend"
LOG_LEVEL="INFO"
LOG_FILE_NAME="app.log"

# --- Directory Settings (paths are relative to the project root) ---
DATA_DIR="data"        # Base directory for application data
OUTPUT_DIR="output"    # Subdirectory within DATA_DIR for processed results
LOG_DIR="logs"         # Subdirectory within DATA_DIR for application logs

# --- Whisper STT Service Settings ---
# URL for the external Whisper microservice container
WHISPER_SERVICE_URL="http://localhost:8001"
WHISPER_MAX_RETRIES=3  # Max retries for Whisper service calls
WHISPER_TIMEOUT=300.0  # Timeout in seconds for Whisper service calls

# --- LLM Provider Configuration ---
# Choose your LLM provider: 'ollama' or 'openai'
LLM_PROVIDER="ollama"

# Settings for Ollama (if LLM_PROVIDER is 'ollama')
OLLAMA_HOST="http://localhost:11434" # URL for the Ollama container
LLM_MODEL_NAME="llama3"           # Default LLM model name (e.g., llama3, mistral)
LLM_MAX_RETRIES=3                 # Max retries for LLM generation
LLM_TEMPERATURE=0.1               # LLM generation temperature (0.0 to 1.0)
LLM_TOP_P=0.95                    # LLM generation top-p (0.0 to 1.0)
OLLAMA_TIMEOUT=120.0              # Timeout in seconds for Ollama service calls

# Settings for OpenAI (if LLM_PROVIDER is 'openai')
OPENAI_API_KEY="sk-mock-openai-key"
